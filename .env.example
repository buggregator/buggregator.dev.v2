# App Template Configuration
# Copy to .env and fill in required values

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================

DB_HOST=localhost
DB_PORT=5432
DB_NAME=app
DB_USER=homestead
DB_PASSWORD=secret

# ============================================================
# PUBLIC URL
# ============================================================

# Base URL for public API
APP_BASE_URL=https://myapp.example.com

# ============================================================
# PUBLIC APP METADATA
# ============================================================

# Application name displayed in the UI
PUBLIC_APP_NAME=App Template

# Contact email addresses (shown on legal pages)
PUBLIC_SUPPORT_EMAIL=support@example.com
PUBLIC_PRIVACY_EMAIL=privacy@example.com
PUBLIC_LEGAL_EMAIL=legal@example.com
